# ──────────────────────────────────────────────────────────────────────────────
# edge/.env.edge  —  Edge Gateway Configuration
# Copy this file to edge/.env.edge and fill in your values.
# This file is NOT the same as the root .env used by app.py.
# ──────────────────────────────────────────────────────────────────────────────

# ── MQTT Broker ──────────────────────────────────────────────────────────────
# Local Mosquitto:  MQTT_HOST=localhost
# Public test broker (no auth): MQTT_HOST=test.mosquitto.org
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
# Set to "true" to enable TLS (port should be 8883)
MQTT_TLS=false

# ── Device Identity ───────────────────────────────────────────────────────────
DEVICE_ID=actuator-01

# ── InfluxDB Source ───────────────────────────────────────────────────────────
#INFLUX_URL=http://192.168.3.14:8086
INFLUX_URL=http://192.168.5.14:8086
INFLUX_TOKEN=pf-OGC6AQFmKy64gOzRM12DZrCuavnWeMgRZ2kDMOk8LYK22evDJnoyKGcmY49EgT8HnMDE9GPQeg30vXeHsRQ==
INFLUX_ORG=belimo
INFLUX_BUCKET=actuator-data
INFLUX_MEASUREMENT=measurements
# How far back to look on first startup (seconds)
INFLUX_LOOKBACK_SECONDS=30

# ── Flask Backend ─────────────────────────────────────────────────────────────
FLASK_INGEST_URL=https://starthack-backend.gentlewave-d2939b38.westeurope.azurecontainerapps.io/api/features/ingest
FLASK_BASELINE_URL=https://starthack-backend.gentlewave-d2939b38.westeurope.azurecontainerapps.io/api/baseline-model/evaluate/combined
FLASK_TOKEN=starthack_front_2026_allow

# ── Gateway Behaviour ─────────────────────────────────────────────────────────
# How many seconds between InfluxDB polls
POLL_SECONDS=2.0
# Per-signal anomaly thresholds (% change between consecutive readings)
TORQUE_ANOMALY_THRESHOLD_PCT=10.0
TEMP_ANOMALY_THRESHOLD_PCT=5.0
# Require this many consecutive threshold breaches before temperature alerting
TEMP_DELTA_PERSISTENCE=3
POWER_ANOMALY_THRESHOLD_PCT=15.0
POSITION_ANOMALY_THRESHOLD_PCT=20.0
# ── Waveform context (sent to evaluate/combined for baseline comparison) ───────
# Options: square, sine, triangle, constant
WAVEFORM_TYPE=square
WAVEFORM_BIAS=50.0
WAVEFORM_AMPLITUDE=20.0
WAVEFORM_FREQUENCY=0.02
# How many readings to batch before calling evaluate/combined
EVAL_BATCH_SIZE=10
# Local buffer size (readings kept in memory when broker is offline)
BUFFER_SIZE=10
